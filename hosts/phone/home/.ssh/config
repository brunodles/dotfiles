# ──────────────────────────────────────────────
# SSH config — Phone (terminal client)
# ──────────────────────────────────────────────
# Homelab hosts accessed via Tailscale (100.x.x.x).
# When on LAN, the Tailscale IPs still work (direct connection).
# No need for separate LAN IPs.

Host *
  IdentityFile ~/.ssh/id_ed25519
  ServerAliveInterval 60
  ServerAliveCountMax 3

Host media
  HostName 100.x.x.x
  User hermes
  Port 22

Host pi
  HostName 100.x.x.x
  User pi
  Port 22

Host vps
  HostName 100.x.x.x
  User hermes
  Port 22

Host silver
  HostName 100.x.x.x
  User bruno
  Port 22

Host android
  HostName 100.x.x.x
  User hermes
  Port 8022
