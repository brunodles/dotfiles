# ── Penpot version ──────────────────────────────────────────────────
PENPOT_VERSION=2.16

# ── Secret key (generate with: openssl rand -base64 48) ─────────────
PENPOT_SECRET_KEY=change-me

# ── Postgres ────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-too

