# ── Required ──────────────────────────────────────────────────
# WireGuard server public IP or domain name.
# "auto" tries to detect it automatically (may pick container IP).
# Set to your VPS public IP or DDNS hostname:
#   SERVERURL=vps.seu-dominio.com
#
# ── Optional (defaults applied) ──────────────────────────────
# SERVERPORT=51820
# PEERS=phone,pihole
# INTERNAL_SUBNET=10.0.0.0/24
