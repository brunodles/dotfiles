# Required: PAT from Gitea (hermes user) for git clone/pull auth
GITEA_URL=http://gitea:3000
GITEA_REPO=hermes/docs
GITEA_TOKEN=

# Webhook secret — shared with Gitea webhook config
# Generate via: openssl rand -hex 16
DOCS_WEBHOOK_SECRET=

# Poll interval in seconds (default: 3600 = 1h)
DOCS_POLL_INTERVAL=3600
