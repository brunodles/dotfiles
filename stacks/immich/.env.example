# Immich configuration
# Copy this file to .env and fill in the values before running docker compose up -d

# The location where your uploaded files are stored
UPLOAD_LOCATION=/media/data/immich/library

# The location where your database files are stored
DB_DATA_LOCATION=/media/data/immich/postgres

# The Immich version to use. Pin to a specific version like "v2.1.0" for stability
IMMICH_VERSION=v3

# Connection secret for Postgres. Change this to a random password.
# Use only A-Za-z0-9, no special characters or spaces
DB_PASSWORD=change_me

# Database credentials (these match Immich defaults — only change if you know what you're doing)
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
