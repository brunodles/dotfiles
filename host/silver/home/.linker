# Configuration file for linker project
# The behavior would change depending on the starting letter of each lines.
# f - link will happen on the file level
# d - link will happen on the directory level
# c - custom link, home target file them the path for the source
# i - for ignored patterns
# # - are ignored
#   - empty lines are also ignored

i .git/*
i .gitignore
i .gitmodules/*
i .md
i README*
i LICENSE*

#c .zshrc .config/zsh/zshrc
f ~/dotfiles/tmux/tmux.conf
d ~/dotfiles/zsh
d ~/dotfiles/i3
d ~/dotfiles/i3blocks
d ~/dotfiles/i3status
f ~/dotfiles/compton.conf
d ~/dotfiles/alacritty
d ~/dotfiles/ghostty
d .local
f .vimrc

i .config/tmux/plugins/*

