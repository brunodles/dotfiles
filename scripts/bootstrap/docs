#!/usr/bin/env bash
# Usage docs
# Set up the docs network + volume for the docstore stack
#
# Creates:
#   - docs      Docker network (isolated, internal)
#   - docs_data Docker named volume (shared with jekyll, calibre)
set -euo pipefail

source "$HOME/dotfiles/scripts/bootstrap/_log.source.sh"

info "Setting up docs infrastructure..."

# ── Docker network ─────────────────────────────────────────────────
if docker network ls --format '{{.Name}}' 2>/dev/null | grep -qx 'docs'; then
  info "  docs network already exists"
else
  if sudo docker network create docs --internal 2>/dev/null; then
    info "  docs network created (internal)"
  elif sudo docker network create docs; then
    warn "  docs network created (non-internal — --internal unsupported on this host)"
  else
    err "  failed to create docs network"
    exit 1
  fi
fi

# ── Docker volume ──────────────────────────────────────────────────
if docker volume ls --format '{{.Name}}' 2>/dev/null | grep -qx 'docs_data'; then
  info "  docs_data volume already exists"
else
  if sudo docker volume create docs_data; then
    info "  docs_data volume created"
  else
    err "  failed to create docs_data volume"
    exit 1
  fi
fi

info "Docs bootstrap complete"
