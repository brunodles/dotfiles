#!/usr/bin/env bash
# password — Fill missing/placeholder secrets in stack .env files
#
# Reads each stack's .env.example (which lists all env vars the compose needs)
# and checks the existing .env (if any). Generates random values for anything
# that's missing or still set to a placeholder (changeme, required, empty, etc.).
#
# Idempotent — existing real values are never overwritten, even between runs.
#
# Usage:
#   password                      # auto — all stacks with .env.example
#   password gitea_vps vikunja    # explicit list
set -euo pipefail

BOOTSTRAP_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$BOOTSTRAP_DIR/_log.source.sh"
source "$BOOTSTRAP_DIR/_env.source.sh"

# ── Generator ────────────────────────────────────────────────────────────
rand_pass()  { openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c32; }

# ── Helpers ──────────────────────────────────────────────────────────────

# Check if a value looks like a placeholder (not a real secret)
is_placeholder() {
  local val="$1"
  [[ -z "$val" ]] && return 0                               # empty
  [[ "${val,,}" == "changeme"* ]] && return 0               # changeme...
  [[ "${val,,}" == "required" ]] && return 0                # required
  [[ "${val,,}" == "null" ]] && return 0                    # null
  return 1                                                   # looks real
}

# Parse a .env/.env.example file into key=value lines (skip blanks/comments)
parse_env() {
  local file="$1"
  [[ ! -f "$file" ]] && return
  while IFS='=' read -r key rest || [[ -n "$key" ]]; do
    key="${key#"${key%%[![:space:]]*}"}"   # trim leading whitespace
    key="${key%"${key##*[![:space:]]}"}"   # trim trailing whitespace
    [[ -z "$key" || "$key" == \#* ]] && continue   # skip blanks and comments
    local val="${rest#\"}" ; val="${val%\"}"        # strip quotes
    val="${val#\'}" ; val="${val%\'}"
    echo "${key}=${val}"
  done < "$file"
}

# Fill missing/placeholder vars for one stack
fill_stack() {
  local stack_dir="$1"
  local stack_name
  stack_name="$(basename "$stack_dir")"
  local example_file="$stack_dir/.env.example"
  local env_file="$stack_dir/.env"

  if [[ ! -f "$example_file" ]]; then
    # Not all stacks need .env generation — skip silently
    return
  fi

  if [[ ! -d "$stack_dir" ]]; then
    warn "password: $stack_name — stack dir not found ($stack_dir), skipping"
    return
  fi

  # ── Read existing .env into associative array ──────────────────────────
  declare -A existing
  if [[ -f "$env_file" ]]; then
    while IFS='=' read -r k v; do
      existing["$k"]="$v"
    done < <(parse_env "$env_file")
  fi

  # ── Read .env.example to know what vars this stack needs ───────────────
  declare -A wanted_vals
  declare -a wanted_order
  while IFS='=' read -r var wval; do
    wanted_vals["$var"]="$wval"
    wanted_order+=("$var")
  done < <(parse_env "$example_file")

  if [[ ${#wanted_order[@]} -eq 0 ]]; then
    info "password: $stack_name — .env.example is empty, nothing to do"
    return
  fi

  # ── Check each var ─────────────────────────────────────────────────────
  local changed=false
  local tmp
  tmp=$(mktemp)

  for var in "${wanted_order[@]}"; do
    local example_val="${wanted_vals[$var]-}"
    local current="${existing[$var]-}"
    local wanted="$current"

    if [[ -z "$current" ]]; then
      # Variable doesn't exist in .env at all
      if is_placeholder "$example_val"; then
        wanted="$(rand_pass)"
      else
        wanted="$example_val"
      fi
      changed=true
    elif is_placeholder "$current"; then
      # Exists but has a placeholder value
      if is_placeholder "$example_val"; then
        wanted="$(rand_pass)"
      else
        wanted="$example_val"
      fi
      changed=true
    else
      # Exists with a real value — keep it
      wanted="$current"
    fi

    echo "${var}=${wanted}" >> "$tmp"
  done

  # ── Write only if something changed ─────────────────────────────────────
  if $changed; then
    if [[ -f "$env_file" ]] && diff -q <(sort "$tmp") <(sort "$env_file") &>/dev/null; then
      info "password: $stack_name — .env complete (values already match)"
    else
      cp "$tmp" "$env_file"
      chmod 600 "$env_file"
      info "password: $stack_name — .env updated (missing/placeholder values filled)"
    fi
  else
    info "password: $stack_name — .env complete (nothing to generate)"
  fi

  rm -f "$tmp"
}

# ── Discovery ────────────────────────────────────────────────────────────
# Find all stacks with .env.example under DOCKGE_STACKS_SRC_DIR.
discover_stacks() {
  local dir
  if [[ ! -d "$DOCKGE_STACKS_SRC_DIR" ]]; then
    error "password: DOCKGE_STACKS_SRC_DIR ($DOCKGE_STACKS_SRC_DIR) not found"
    exit 1
  fi
  for dir in "$DOCKGE_STACKS_SRC_DIR"/*/; do
    [[ -f "$dir/.env.example" ]] && echo "$dir"
  done
}

# ── Main ────────────────────────────────────────────────────────────────
if [[ $# -eq 0 ]]; then
  # Auto-detect
  while IFS= read -r dir; do
    fill_stack "$dir"
  done < <(discover_stacks)
else
  # Explicit list
  for name in "$@"; do
    local dir="$DOCKGE_STACKS_SRC_DIR/$name"
    fill_stack "$dir"
  done
fi
